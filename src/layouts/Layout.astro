---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Esteban Daniel Mancilla Lozoya — Software Engineering Student & Backend Specialist with 2+ years of experience.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts: Syne (display) + DM Sans (body) + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-canvas text-slate-200 font-body antialiased overflow-x-hidden">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --clr-canvas: #020209;
    --clr-surface: #08080f;
    --clr-card: #0c0c16;
    --clr-blue: #3b82f6;
    --clr-indigo: #6366f1;
    --clr-teal: #14b8a6;
    --clr-violet: #8b5cf6;
    --clr-slate: #94a3b8;
    --border-subtle: rgba(255, 255, 255, 0.06);
    --border-mid: rgba(255, 255, 255, 0.10);
  }

  html {
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  /* Custom scrollbar */
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: var(--clr-canvas); }
  ::-webkit-scrollbar-thumb {
    background: rgba(99, 102, 241, 0.45);
    border-radius: 99px;
  }
  ::-webkit-scrollbar-thumb:hover { background: rgba(99, 102, 241, 0.7); }

  /* ── Scroll-reveal ─────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger helpers */
  .reveal-delay-1 { transition-delay: 0.1s; }
  .reveal-delay-2 { transition-delay: 0.2s; }
  .reveal-delay-3 { transition-delay: 0.3s; }
  .reveal-delay-4 { transition-delay: 0.4s; }
  .reveal-delay-5 { transition-delay: 0.5s; }

  /* ── Connect button: slide-fill left → right ──────── */
  .btn-connect {
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.32s ease, border-color 0.32s ease;
  }
  .btn-connect::before {
    content: '';
    position: absolute;
    inset: 0;
    left: -105%;
    transition: left 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: -1;
  }
  .btn-connect:hover::before { left: 0; }

  /* Color variants */
  .btn-connect-blue::before  { background: #3b82f6; }
  .btn-connect-blue:hover    { color: #fff; border-color: #3b82f6; }

  .btn-connect-ghost::before { background: rgba(255,255,255,0.09); }
  .btn-connect-ghost:hover   { color: #fff; }

  .btn-connect-teal::before  { background: #14b8a6; }
  .btn-connect-teal:hover    { color: #fff; border-color: #14b8a6; }

  /* ── Section label (small uppercase label above title) */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* ── Thin gradient divider ─────────────────────────── */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
    margin: 0;
  }

  /* ── Glowing dot ──────────────────────────────────── */
  .glow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    animation: glowPulse 2.5s ease-in-out infinite;
  }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.5; box-shadow: 0 0 4px currentColor; }
    50%       { opacity: 1;   box-shadow: 0 0 10px currentColor, 0 0 20px currentColor; }
  }

  /* ── Tech pill tags ──────────────────────────────── */
  .tech-pill {
    display: inline-flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #94a3b8;
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .tech-pill:hover {
    border-color: rgba(99, 102, 241, 0.4);
    color: #c7d2fe;
    background: rgba(99, 102, 241, 0.08);
  }

  /* ── Card glass effect ───────────────────────────── */
  .glass-card {
    background: rgba(12, 12, 22, 0.9);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }
  .glass-card:hover {
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    transform: translateY(-2px);
  }
</style>
