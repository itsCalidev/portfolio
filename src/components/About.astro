---
---

<section id="about" class="relative py-28 px-6 lg:px-12">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto mt-16">

    <!-- ── Section header ─────────────────────────── -->
    <div class="reveal">
      <div class="section-label text-slate-400">
        <span class="glow-dot bg-slate-400" style="color:#94a3b8;"></span>
        About Me
      </div>
      <h2
        class="font-display font-bold text-white leading-tight"
        style="font-size: clamp(2rem, 5vw, 3.5rem);"
      >
        The Human Behind<br />
        <span class="text-slate-500">the Code</span>
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

      <!-- ── Text content (3 cols) ──────────────────── -->
      <div class="lg:col-span-3 flex flex-col gap-6">

        <!-- Placeholder paragraphs — replace with your story -->
        <div class="glass-card rounded-2xl p-7 border border-white/6 reveal reveal-delay-1">
          <p class="text-slate-400 leading-relaxed">
            <!-- ✏️ PLACEHOLDER — Edit this block with your personal story -->
            Hey! I'm Esteban, a Software Engineering student passionate about
            building robust backend systems that actually make a difference. I've
            spent the last couple of years leading backend teams on real-world
            projects — from naval inventory management for the Mexican Navy to
            industrial safety platforms — and I genuinely love the challenge of
            translating complex requirements into clean, scalable architectures.
          </p>
        </div>

        <div class="glass-card rounded-2xl p-7 border border-white/6 reveal reveal-delay-2">
          <p class="text-slate-400 leading-relaxed">
            <!-- ✏️ PLACEHOLDER — Edit this block with your background -->
            <!-- [Add more about your background, where you study, what drives you,
            or any personal interests and hobbies here. This is your space to
            show the person behind the portfolio — share what makes you
            unique and what you're looking for in your next opportunity.] -->
                       More description

          </p>
        </div>

        <div class="glass-card rounded-2xl p-7 border border-white/6 reveal reveal-delay-3">
          <p class="text-slate-400 leading-relaxed">
            <!-- ✏️ PLACEHOLDER — Edit this block with your interests/goals -->
            <!-- [Add a third paragraph about your goals, aspirations, or areas
            you're currently exploring. What kind of team do you want to join?
            What problems excite you most? Where do you see yourself in 3–5 years?] -->
                       More description

          </p>
        </div>

        <!-- ── CV Buttons ──────────────────────────── -->
        <div class="flex flex-wrap gap-3 reveal reveal-delay-4 mt-2">
          <!-- CV English -->
          <a
            href="/Esteban_en_cv.pdf"
            download
            class="btn-connect btn-connect-blue
                   inline-flex items-center gap-2.5 px-5 py-3 rounded-xl
                   border border-blue-400/30 text-blue-300 font-medium text-sm"
            aria-label="Download CV in English"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.8" stroke="currentColor" class="w-4 h-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            Download CV — English
          </a>

          <!-- CV Spanish -->
          <a
            href="/Esteban_es_cv.pdf"
            download
            class="btn-connect btn-connect-ghost
                   inline-flex items-center gap-2.5 px-5 py-3 rounded-xl
                   border border-white/12 text-slate-300 font-medium text-sm"
            aria-label="Descargar CV en Español"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                 stroke-width="1.8" stroke="currentColor" class="w-4 h-4 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
            Descargar CV — Español
          </a>
        </div>
      </div>

      <!-- ── Side info panel (2 cols) ──────────────── -->
      <aside class="lg:col-span-2 flex flex-col gap-4">

        <!-- Quick facts card -->
        <div
          class="glass-card rounded-2xl p-6 border border-white/6 reveal reveal-delay-2"
        >
          <h3 class="font-display font-semibold text-white text-sm mb-4 tracking-wide">
            Quick Facts
          </h3>
          <ul class="flex flex-col gap-3">
            {[
              { label: 'Location',   value: 'México 🇲🇽' },
              { label: 'Status',     value: '📚 Currently Studying' },
              { label: 'Focus',      value: 'Backend Engineering' },
              { label: 'Languages',  value: 'Spanish (native), English (B2)' },
              { label: 'Open to',    value: 'Internships & Junior roles' },
            ].map(({ label, value }) => (
              <li class="flex items-start justify-between gap-4 text-sm">
                <span class="text-slate-600 font-mono shrink-0">{label}</span>
                <span class="text-slate-300 text-right">{value}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Interests -->
        <div
          class="glass-card rounded-2xl p-6 border border-white/6 reveal reveal-delay-3"
        >
          <h3 class="font-display font-semibold text-white text-sm mb-4 tracking-wide">
            Outside Code
          </h3>
          <div class="flex flex-wrap gap-2">
            {['3D Modeling ✦', 'Game Dev ✦', 'Music ✦', 'Open Source ✦', 'Reading ✦'].map((item) => (
              <span class="tech-pill">{item}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>
