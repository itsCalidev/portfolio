---

interface Project {
  title:       string;
  subtitle:    string;
  description: string;
  tags:        string[];
  type:        'live' | 'github' | 'private';
  url:         string;
  gradient:    string;
  visualType?: 'icon' | 'gallery';
  icon?:       string;
  images?:     string[];
  alts?:       string[];
}

const projects: Project[] = [
  // ── Proyectos existentes: sin ningún cambio ──────────────────────────────
  {
    title:       'NauticStock',
    subtitle:    'Naval Inventory Management System',
    description: 'Full-stack inventory system for the Mexican Navy. Handles real-time stock tracking, procurement workflows, and logistics reporting at scale.',
    tags:        ['Node.js', 'React', 'MySQL', 'Docker'],
    type:        'github',
    url:         'https://github.com/itsCalidev/nauticstock',
    gradient:    'from-indigo-900/60 via-blue-900/40 to-slate-900/60',
    icon:        '⚓',
    // visualType no declarado → se trata como 'icon' automáticamente
  },
  {
    title:       'Domind Main Platform',
    subtitle:    'Climate Diagnosis',
    description: 'Web app for organizational climate and industrial safety diagnostics. Includes a guided assessment, visual results dashboard with PDF export, and a B2B admin panel.',
    tags:        ['Astro', 'React', 'Tailwind CSS', 'TypeScript', 'PostgreSQL'],
    type:        'live',
    url:         'https://transformacion.domind.com.mx/',
    gradient:    'from-blue-900/60 via-cyan-900/30 to-slate-900/60',
    visualType:  'gallery',
    images: [
      '/projects/domind-web/landing.png',
      '/projects/domind-web/solutions.png',
      '/projects/domind-web/workshops.png',
      '/projects/domind-web/diagnostic-init.png',
      '/projects/domind-web/diagnostic-results.png',
    ],
    alts: [
      'Domind — Hero section with CTA',
      'Domind — Solutions overview',
      'Domind — Workshops catalog',
      'Domind — Diagnostic questionnaire',
      'Domind — Results dashboard with charts',
    ],
  },
  {
    title:       'iOS Mobile App',
    subtitle:    'Cross-Platform Mobile Backend',
    description: 'Co-led the backend for an iOS-first mobile application. Designed REST API contracts, authentication flows, and cloud storage integration.',
    tags:        ['NestJS', 'MongoDB', 'AWS S3', 'AWS SES', 'TypeScript', 'JWT'],
    type:        'private',
    url:         'https://github.com/itsCalidev',
    gradient:    'from-teal-900/60 via-emerald-900/30 to-slate-900/60',
    icon:        '📱',
  },
  {
    title:       'Social Network Platform',
    subtitle:    'Scalable Social Backend & DB Architecture',
    description: 'Architected the complete backend and database layer for a full-featured social platform with real-time messaging and media uploads.',
    tags:        ['Laravel', 'Javascript', 'MySQL'],
    type:        'github',
    url:         'https://github.com/itsCalidev/For-Us',
    gradient:    'from-violet-900/60 via-purple-900/30 to-slate-900/60',
    icon:        '🌐',
  },
  {
    title:       'Cine-Hub Revamp',
    subtitle:    'Refactoring of a legacy platform',
    description: 'Originally built with PHP and MySQL, the frontend was re-architected into an ultra-fast static site using Astro and Content Collections (JSON), eliminating server costs.',
    tags:        ['Astro', 'Tailwind CSS', 'JSON'],
    type:        'live',
    url:         'https://cinehub-web.vercel.app/',
    gradient:    'from-amber-900/40 via-yellow-900/20 to-slate-900/60',
    visualType:  'gallery',
    images: [
      '/projects/cine-hub/carrusel.png',
      '/projects/cine-hub/movies.png',
      '/projects/cine-hub/series.png',
      '/projects/cine-hub/reviews.png',
      '/projects/cine-hub/awards.png',
    ],
    alts: [
      'Cine-Hub — Hero carousel and navigation',
      'Cine-Hub — Movies section with filters',
      'Cine-Hub — Series section with platform dropdown',
      'Cine-Hub — Review cards with star rating',
      'Cine-Hub — Awards Movies page with presentation of winners and nominees',
    ],
  },
   {
    title:       'Domind Mobile App',
    subtitle:    'Android Mobile Application',
    description: 'Risk perception and Security awareness app for Android devices. Currently working on this project, stay tuned for updates!',
    tags:        ['React Native', 'React', 'NestJS', 'Prisma'],
    type:        'private',
    url:         'https://example.com',
    gradient:    'from-rose-900/40 via-orange-900/20 to-slate-900/60',
    icon:        '📱',
  },
];
---

<section id="projects" class="relative py-28 px-6 lg:px-12">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto mt-16">

    <!-- ── Section header ─────────────────────────── -->
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <div class="section-label text-teal-400">
          <span class="glow-dot bg-teal-400" style="color:#14b8a6;"></span>
          Projects
        </div>
        <h2
          class="font-display font-bold text-white leading-tight"
          style="font-size: clamp(2rem, 5vw, 3.5rem);"
        >
          What I've Built
        </h2>
        <p class="mt-3 text-slate-500 max-w-lg">
          A selection of systems, platforms, and applications I've engineered.
        </p>
      </div>

      <a
        href="https://github.com/itsCalidev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white
               border border-white/8 hover:border-white/20 px-4 py-2 rounded-lg
               transition-all duration-300 shrink-0"
      >
        View all on GitHub
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

    <!-- ── Project Grid ───────────────────────────── -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, i) => {

        // Resuelve el modo visual; si no está declarado es 'icon'
        const isGallery = project.visualType === 'gallery'
          && Array.isArray(project.images)
          && project.images.length > 0;

        // Slug del proyecto para el lightbox
        const galleryId = project.title
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '');

        return (
          <article
            class={`glass-card reveal reveal-delay-${(i % 3) + 1} rounded-2xl overflow-hidden flex flex-col group`}
          >

            {/* ── HEADER VISUAL — h-40 exacto en ambos modos ── */}
            {isGallery ? (

              // ── MODO GALERÍA ─────────────────────────────────────────────
              // Mismo h-40 que el original. La imagen usa object-cover para
              // rellenar sin distorsión. El resto de la tarjeta no cambia.
              <div
                class="relative h-40 overflow-hidden cursor-pointer"
                data-gallery-id={galleryId}
                data-images={JSON.stringify(project.images)}
                data-alts={JSON.stringify(project.alts ?? [])}
                data-open-lightbox
                data-index="0"
                role="button"
                tabindex="0"
                aria-label={`Ver galería de ${project.title}`}
              >
                {/* Imagen principal (primera del array) */}
                <img
                  src={project.images![0]}
                  alt={project.alts?.[0] ?? project.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover object-top
                         transition-transform duration-500 ease-out
                         group-hover:scale-105"
                />

                {/* Overlay oscuro igual al gradiente bottom del modo icono */}
                <div class="absolute bottom-0 inset-x-0 h-16
                             bg-gradient-to-t from-[#0c0c16] to-transparent" />

                {/* Badge contador de imágenes — aparece al hover */}
                {project.images!.length > 1 && (
                  <div class="
                    absolute top-3 right-3
                    flex items-center gap-1.5 px-2.5 py-1 rounded-lg
                    bg-black/60 backdrop-blur-sm border border-white/10
                    text-white text-xs font-medium
                    opacity-0 group-hover:opacity-100
                    translate-y-1 group-hover:translate-y-0
                    transition-all duration-300 pointer-events-none
                  ">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7"/>
                    </svg>
                    {project.images!.length} screenshots
                  </div>
                )}

                {/* Dot strip — thumbnails en miniatura al fondo */}
                {project.images!.length > 1 && (
                  <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-1.5 pointer-events-none">
                    {project.images!.slice(0, 5).map((_, idx) => (
                      <span class={`
                        rounded-full transition-all duration-300
                        ${idx === 0 ? 'w-4 h-1.5 bg-white/80' : 'w-1.5 h-1.5 bg-white/30'}
                      `} />
                    ))}
                  </div>
                )}
              </div>

            ) : (

              // ── MODO ICONO (original, sin cambio alguno) ─────────────────
              <div class={`relative h-40 bg-gradient-to-br ${project.gradient} overflow-hidden`}>
                <div
                  class="absolute inset-0 opacity-30"
                  style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
                         linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
                         background-size: 20px 20px;"
                />
                <div class="absolute inset-0 flex items-center justify-center">
                  <span
                    class="text-5xl select-none opacity-70 group-hover:scale-110 transition-transform duration-500 ease-out"
                    role="img"
                    aria-label={project.title}
                  >
                    {project.icon}
                  </span>
                </div>
                <div class="absolute bottom-0 inset-x-0 h-16
                             bg-gradient-to-t from-[#0c0c16] to-transparent" />
              </div>

            )}

            {/* ── Card body — idéntico al original ── */}
            <div class="flex flex-col flex-1 p-5 gap-3">
              <div>
                <h3 class="font-display font-semibold text-white text-base leading-snug">
                  {project.title}
                </h3>
                <p class="text-xs text-slate-500 mt-0.5 font-mono">{project.subtitle}</p>
              </div>

              <p class="text-slate-400 text-sm leading-relaxed flex-1">
                {project.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="tech-pill">{tag}</span>
                ))}
              </div>

              <div class="pt-1">
                {project.type === 'live' ? (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium text-teal-300
                           hover:text-white border border-teal-400/25 hover:border-teal-400/60
                           px-4 py-2 rounded-lg transition-all duration-300
                           hover:bg-teal-400/8 w-full justify-center"
                  >
                    View Live
                  </a>
                ) : project.type === 'github' ? (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-medium text-slate-300
                           hover:text-white border border-white/10 hover:border-white/25
                           px-4 py-2 rounded-lg transition-all duration-300
                           hover:bg-white/5 w-full justify-center"
                  >
                    View GitHub
                  </a>
                ) : (
                  <span
                    class="inline-flex items-center gap-2 text-sm font-medium text-slate-500
                           border border-slate-500/20 px-4 py-2 rounded-lg cursor-not-allowed
                           transition-all duration-300 hover:bg-slate-700/10 w-full justify-center"
                  >
                    Private Project
                  </span>
                )}
              </div>
            </div>

          </article>
        );
      })}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════════ -->
<!--  LIGHTBOX — montado fuera del grid para no afectar el layout              -->
<!--  Solo aparece cuando alguna tarjeta en modo gallery dispara el evento.    -->
<!-- ══════════════════════════════════════════════════════════════════════════ -->
<div
  id="lb-backdrop"
  role="dialog"
  aria-modal="true"
  aria-label="Project screenshot gallery"
  class="fixed inset-0 z-[9999] flex items-center justify-center
         bg-black/90 backdrop-blur-sm
         opacity-0 pointer-events-none transition-opacity duration-300"
>
  <!-- Clic en el fondo para cerrar -->
  <div id="lb-bg" class="absolute inset-0" aria-hidden="true" />

  <div class="relative z-10 flex flex-col items-center w-full max-w-4xl mx-4">

    <!-- Barra superior -->
    <div class="flex items-center justify-between w-full mb-3 px-1">
      <span id="lb-counter" class="text-slate-400 text-sm tabular-nums" aria-live="polite">
        1 / 1
      </span>
      <button
        id="lb-close"
        type="button"
        aria-label="Close gallery"
        class="w-9 h-9 flex items-center justify-center rounded-xl
               bg-slate-800 hover:bg-slate-700 border border-slate-600/50
               text-slate-300 hover:text-white transition-all duration-200
               focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-400"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Fila: prev · imagen · next -->
    <div class="flex items-center gap-3 w-full">
      <button id="lb-prev" type="button" aria-label="Previous screenshot"
        class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-xl
               bg-slate-800/80 hover:bg-teal-600 border border-slate-600/40 hover:border-teal-500
               text-slate-300 hover:text-white transition-all duration-200
               focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <div class="flex-1 overflow-hidden rounded-2xl bg-slate-900 border border-slate-700/50
                  shadow-2xl shadow-black/60 flex items-center justify-center min-h-[160px]">
        <div id="lb-skeleton" class="w-full aspect-video bg-slate-800 animate-pulse rounded-2xl" />
        <img id="lb-img" src="" alt="" loading="eager" decoding="async"
             class="w-full h-auto max-h-[72vh] object-contain rounded-2xl opacity-0 transition-opacity duration-300" />
      </div>

      <button id="lb-next" type="button" aria-label="Next screenshot"
        class="flex-shrink-0 w-10 h-10 flex items-center justify-center rounded-xl
               bg-slate-800/80 hover:bg-teal-600 border border-slate-600/40 hover:border-teal-500
               text-slate-300 hover:text-white transition-all duration-200
               focus:outline-none focus-visible:ring-2 focus-visible:ring-teal-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- Alt text + dots -->
    <p id="lb-alt" class="mt-3 text-slate-400 text-sm text-center line-clamp-1 px-12"
       aria-live="polite"></p>
    <div id="lb-dots" class="flex items-center justify-center gap-2 mt-3"
         role="tablist" aria-label="Screenshots"></div>
  </div>
</div>

<script>
// ── Estado ─────────────────────────────────────────────────────────────────
let lbImages:  string[] = [];
let lbAlts:    string[] = [];
let lbCurrent: number   = 0;

const backdrop = document.getElementById('lb-backdrop')!;
const lbBg     = document.getElementById('lb-bg')!;
const lbClose  = document.getElementById('lb-close')!;
const lbPrev   = document.getElementById('lb-prev')!;
const lbNext   = document.getElementById('lb-next')!;
const lbImg    = document.getElementById('lb-img')    as HTMLImageElement;
const lbSkel   = document.getElementById('lb-skeleton')!;
const lbCount  = document.getElementById('lb-counter')!;
const lbAlt    = document.getElementById('lb-alt')!;
const lbDots   = document.getElementById('lb-dots')!;

// ── Abrir desde clic en la tarjeta ─────────────────────────────────────────
document.addEventListener('click', (e) => {
  const trigger = (e.target as Element).closest('[data-open-lightbox]') as HTMLElement | null;
  if (!trigger) return;

  const images = JSON.parse(trigger.dataset.images ?? '[]') as string[];
  const alts   = JSON.parse(trigger.dataset.alts   ?? '[]') as string[];
  const index  = parseInt(trigger.dataset.index    ?? '0',  10);

  if (!images.length) return;

  lbImages  = images;
  lbAlts    = alts;
  lbCurrent = index;

  buildDots();
  goTo(lbCurrent);
  openLb();
});

// Apertura via teclado (Enter / Space) en el div con role=button
document.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' || e.key === ' ') {
    const trigger = (document.activeElement as HTMLElement)?.closest('[data-open-lightbox]') as HTMLElement | null;
    if (trigger) { trigger.click(); e.preventDefault(); }
  }
});

// ── Abrir / Cerrar ─────────────────────────────────────────────────────────
function openLb() {
  backdrop.classList.remove('opacity-0', 'pointer-events-none');
  document.body.style.overflow = 'hidden';
  lbClose.focus();
}
function closeLb() {
  backdrop.classList.add('opacity-0', 'pointer-events-none');
  document.body.style.overflow = '';
  setTimeout(() => { lbImg.src = ''; }, 300);
}

lbClose.addEventListener('click', closeLb);
lbBg.addEventListener('click', closeLb);

// ── Navegar ────────────────────────────────────────────────────────────────
function goTo(idx: number) {
  lbCurrent = (idx + lbImages.length) % lbImages.length;

  // Mostrar skeleton mientras carga
  lbImg.classList.add('opacity-0');
  lbSkel.classList.remove('hidden');

  const loader = new Image();
  loader.onload = loader.onerror = () => {
    lbImg.src = lbImages[lbCurrent];
    lbImg.alt = lbAlts[lbCurrent] ?? '';
    lbImg.classList.remove('opacity-0');
    lbSkel.classList.add('hidden');
  };
  loader.src = lbImages[lbCurrent];

  lbCount.textContent = `${lbCurrent + 1} / ${lbImages.length}`;
  lbAlt.textContent   = lbAlts[lbCurrent] ?? '';

  // Ocultar flechas si hay una sola imagen
  const single = lbImages.length <= 1;
  lbPrev.style.visibility = single ? 'hidden' : 'visible';
  lbNext.style.visibility = single ? 'hidden' : 'visible';

  updateDots();
}

lbPrev.addEventListener('click', () => goTo(lbCurrent - 1));
lbNext.addEventListener('click', () => goTo(lbCurrent + 1));

// ── Dots ───────────────────────────────────────────────────────────────────
function buildDots() {
  lbDots.innerHTML = '';
  if (lbImages.length <= 1) return;

  lbImages.forEach((_, i) => {
    const d = document.createElement('button');
    d.type = 'button';
    d.setAttribute('role', 'tab');
    d.setAttribute('aria-label', `Screenshot ${i + 1}`);
    d.className = 'rounded-full border-0 p-0 cursor-pointer transition-all duration-300 h-1.5 focus:outline-none';
    d.addEventListener('click', () => goTo(i));
    lbDots.appendChild(d);
  });

  updateDots();
}

function updateDots() {
  lbDots.querySelectorAll('button').forEach((d, i) => {
    if (i === lbCurrent) {
      d.className = d.className.replace(/w-\S+/, '');
      d.classList.add('w-5', 'bg-teal-400');
      d.classList.remove('w-1.5', 'bg-slate-600');
    } else {
      d.classList.remove('w-5', 'bg-teal-400');
      d.classList.add('w-1.5', 'bg-slate-600');
    }
  });
}

// ── Teclado ────────────────────────────────────────────────────────────────
document.addEventListener('keydown', (e) => {
  if (backdrop.classList.contains('pointer-events-none')) return;
  if (e.key === 'Escape')     closeLb();
  if (e.key === 'ArrowLeft')  goTo(lbCurrent - 1);
  if (e.key === 'ArrowRight') goTo(lbCurrent + 1);
});

// ── Swipe ──────────────────────────────────────────────────────────────────
let touchX = 0;
backdrop.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; },        { passive: true });
backdrop.addEventListener('touchend',   (e) => {
  const d = touchX - e.changedTouches[0].clientX;
  if (Math.abs(d) > 50) goTo(d > 0 ? lbCurrent + 1 : lbCurrent - 1);
}, { passive: true });
</script>
