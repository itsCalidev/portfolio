---
interface Project {
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  type: 'live' | 'github'| 'private';
  url: string;
  gradient: string;
  icon: string;
}

const projects: Project[] = [
  {
    title: 'NauticStock',
    subtitle: 'Naval Inventory Management System',
    description:
      'Full-stack inventory system for the Mexican Navy. Handles real-time stock tracking, procurement workflows, and logistics reporting at scale.',
    tags: ['Node.js', 'React', 'MySQL', 'Docker'],
    type: 'github',
    url: 'https://github.com/itsCalidev/nauticstock',
    gradient: 'from-indigo-900/60 via-blue-900/40 to-slate-900/60',
    icon: '⚓',
  },
  {
    title: 'Domind Main Platform',
    subtitle: 'Climate Diagnosis',
    description:
      'Web app for organizational climate and industrial safety diagnostics. Currently under active development for Domind Desarrollo Organizacional.',
    tags: ['Astro', 'React', 'Tailwind CSS', 'TypeScript', 'SQL'],
    type: 'live',
    url: 'https://diagnostico.domind.com.mx/',
    gradient: 'from-blue-900/60 via-cyan-900/30 to-slate-900/60',
    icon: '🏭',
  },
  {
    title: 'iOS Mobile App',
    subtitle: 'Cross-Platform Mobile Backend',
    description:
      'Co-led the backend for an iOS-first mobile application. Designed REST API contracts, authentication flows, and cloud storage integration.',
    tags: ['NestJS', 'MongoDB', 'AWS S3', 'AWS SES', 'TypeScript', 'JWT'],
    type: 'private',
    url: 'https://github.com/itsCalidev',
    gradient: 'from-teal-900/60 via-emerald-900/30 to-slate-900/60',
    icon: '📱',
  },
  {
    title: 'Social Network Platform',
    subtitle: 'Scalable Social Backend & DB Architecture',
    description:
      'Architected the complete backend and database layer for a full-featured social platform with real-time messaging and media uploads.',
    tags: ['Laravel', 'Javascript', 'MySQL'],
    type: 'github',
    url: 'https://github.com/itsCalidev/For-Us',
    gradient: 'from-violet-900/60 via-purple-900/30 to-slate-900/60',
    icon: '🌐',
  },
  {
    title: '[Project]',
    subtitle: 'title',
    description:
      'description',
    tags: ['Tech 1', 'Tech 2', 'Tech 3'],
    type: 'live',
    url: 'https://example.com',
    gradient: 'from-rose-900/40 via-orange-900/20 to-slate-900/60',
    icon: '✦',
  },
  {
    title: 'Cine-Hub Revamp',
    subtitle:'Refactoring of a legacy platform',
    description:
      'Originally built with PHP and MySQL, the frontend was re-architected into an ultra-fast static site using Astro and Content Collections (JSON), eliminating server costs.',
    tags: ['Astro', 'Tailwind CSS', 'JSON'],
    type: 'live',
    url: 'https://cinehub-web.vercel.app/',
    gradient: 'from-amber-900/40 via-yellow-900/20 to-slate-900/60',
    icon: '✦',
  },
];
---

<section id="projects" class="relative py-28 px-6 lg:px-12">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto mt-16">

    <!-- ── Section header ─────────────────────────── -->
    <div class="reveal flex flex-wrap items-end justify-between gap-4">
      <div>
        <div class="section-label text-teal-400">
          <span class="glow-dot bg-teal-400" style="color:#14b8a6;"></span>
          Projects
        </div>
        <h2
          class="font-display font-bold text-white leading-tight"
          style="font-size: clamp(2rem, 5vw, 3.5rem);"
        >
          What I've Built
        </h2>
        <p class="mt-3 text-slate-500 max-w-lg">
          A selection of systems, platforms, and applications I've engineered.
        </p>
      </div>

      <a
        href="https://github.com/itsCalidev"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white
               border border-white/8 hover:border-white/20 px-4 py-2 rounded-lg
               transition-all duration-300 shrink-0"
      >
        View all on GitHub
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke-width="1.8" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
        </svg>
      </a>
    </div>

    <!-- ── Project Grid ───────────────────────────── -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project, i) => (
        <article
          class={`glass-card reveal reveal-delay-${(i % 3) + 1} rounded-2xl overflow-hidden
                  flex flex-col group`}
        >
          <!-- Image placeholder -->
          <div
            class={`relative h-40 bg-gradient-to-br ${project.gradient} overflow-hidden`}
          >
            <!-- Grid pattern on the card image area -->
            <div
              class="absolute inset-0 opacity-30"
              style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
                     linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
                     background-size: 20px 20px;"
            ></div>
            <!-- Centered icon / emoji -->
            <div class="absolute inset-0 flex items-center justify-center">
              <span
                class="text-5xl select-none opacity-70 group-hover:scale-110 transition-transform duration-500 ease-out"
                role="img"
                aria-label={project.title}
              >
                {project.icon}
              </span>
            </div>
            <!-- Bottom gradient -->
            <div class="absolute bottom-0 inset-x-0 h-16
                         bg-gradient-to-t from-[#0c0c16] to-transparent"></div>
          </div>

          <!-- Card body -->
          <div class="flex flex-col flex-1 p-5 gap-3">
            <!-- Title & subtitle -->
            <div>
              <h3 class="font-display font-semibold text-white text-base leading-snug">
                {project.title}
              </h3>
              <p class="text-xs text-slate-500 mt-0.5 font-mono">{project.subtitle}</p>
            </div>

            <!-- Description -->
            <p class="text-slate-400 text-sm leading-relaxed flex-1">
              {project.description}
            </p>

            <!-- Tech stack pills -->
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="tech-pill">{tag}</span>
              ))}
            </div>

            <!-- Action button -->
            <div class="pt-1">
{
  project.type === 'live' ? (
    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-medium text-teal-300
             hover:text-white border border-teal-400/25 hover:border-teal-400/60
             px-4 py-2 rounded-lg transition-all duration-300
             hover:bg-teal-400/8 w-full justify-center"
    >
      {/* icon */}
      View Live
    </a>

  ) : project.type === 'github' ? (

    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-medium text-slate-300
             hover:text-white border border-white/10 hover:border-white/25
             px-4 py-2 rounded-lg transition-all duration-300
             hover:bg-white/5 w-full justify-center"
    >
      {/* icon */}
      View GitHub
    </a>

  ) : (

    <span
      class="inline-flex items-center gap-2 text-sm font-medium text-slate-500
             border border-slate-500/20 px-4 py-2 rounded-lg cursor-not-allowed
             transition-all duration-300 hover:bg-slate-700/10 w-full justify-center"
    >
      {/* icon */}
      Private Project
    </span>

  )
}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
