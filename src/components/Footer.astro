---
const currentYear = new Date().getFullYear();

const footerNav = [
  { href: '#hero',       label: 'Home'       },
  { href: '#experience', label: 'Experience' },
  { href: '#projects',   label: 'Projects'   },
  { href: '#tech',       label: 'Tech Stack' },
  { href: '#about',      label: 'About'      },
];
---

<footer class="relative border-t border-white/6 bg-[#04040b]">

  <!-- Top gradient -->
  <div
    class="absolute top-0 inset-x-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(99,102,241,0.4), transparent);"
  ></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

      <!-- ── Left: Name & tagline ─────────────────── -->
      <div class="flex flex-col gap-4">
        <a
          href="#hero"
          class="font-display font-bold text-xl tracking-tight text-white
                 hover:text-blue-400 transition-colors duration-300 w-fit"
        >
          <span class="text-blue-400">E</span>steban<span class="text-slate-600">.</span>
        </a>
        <p class="text-sm text-slate-500 leading-relaxed max-w-xs">
          Software Engineering Student building reliable, high-performance
          backend systems with a passion for clean architecture.
        </p>
        <p class="font-mono text-xs text-slate-700">
          © {currentYear} Esteban Daniel Mancilla Lozoya
        </p>
      </div>

      <!-- ── Center: Connect (LinkedIn + Email only) ─ -->
      <div class="flex flex-col gap-4">
        <h3 class="font-mono text-xs text-slate-600 tracking-widest uppercase">Connect</h3>
        <div class="flex flex-col gap-3">

          <!-- LinkedIn -->
          <a
            href="https://linkedin.com/in/esteban-mancilla"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 text-sm text-slate-400
                   hover:text-blue-300 transition-colors duration-300 group w-fit"
            aria-label="LinkedIn profile"
          >
            <span
              class="w-8 h-8 rounded-lg border border-white/8 bg-white/3
                     flex items-center justify-center
                     group-hover:border-blue-400/40 group-hover:bg-blue-400/8
                     transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                   fill="currentColor" class="w-3.5 h-3.5">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            LinkedIn
          </a>

          <!-- Email -->
          <a
            href="mailto:emancillalozoya@gmail.com"
            class="inline-flex items-center gap-3 text-sm text-slate-400
                   hover:text-teal-300 transition-colors duration-300 group w-fit"
            aria-label="Send an email"
          >
            <span
              class="w-8 h-8 rounded-lg border border-white/8 bg-white/3
                     flex items-center justify-center
                     group-hover:border-teal-400/40 group-hover:bg-teal-400/8
                     transition-all duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                   stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </span>
            emancillalozoya@gmail.com
          </a>
        </div>
      </div>

      <!-- ── Right: Navigation links ─────────────── -->
      <div class="flex flex-col gap-4">
        <h3 class="font-mono text-xs text-slate-600 tracking-widest uppercase">Navigation</h3>
        <nav class="flex flex-col gap-2.5" aria-label="Footer navigation">
          {footerNav.map((link) => (
            <a
              href={link.href}
              class="text-sm text-slate-400 hover:text-white transition-colors duration-200
                     w-fit group flex items-center gap-2"
            >
              <span
                class="h-px w-3 bg-slate-700 group-hover:w-5 group-hover:bg-indigo-400
                       transition-all duration-300"
              ></span>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- ── Bottom bar ──────────────────────────────── -->
    <div class="mt-14 pt-6 border-t border-white/5 flex flex-wrap items-center justify-between gap-4">
      <p class="font-mono text-xs text-slate-700">
        Designed &amp; built with Astro + Tailwind CSS
      </p>
      <a
        href="#hero"
        class="inline-flex items-center gap-2 text-xs text-slate-600
               hover:text-white transition-colors duration-300 group"
        aria-label="Back to top"
      >
        Back to top
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke-width="2" stroke="currentColor"
             class="w-3.5 h-3.5 group-hover:-translate-y-0.5 transition-transform duration-300">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/>
        </svg>
      </a>
    </div>
  </div>
</footer>
