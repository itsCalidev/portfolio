---
interface SkillGroup {
  category: string;
  icon: string;
  accent: string;
  accentText: string;
  accentBorder: string;
  accentBg: string;
  skills: { name: string; level?: 'expert' | 'proficient' | 'familiar' }[];
}

const skillGroups: SkillGroup[] = [
  {
    category: 'Languages',
    icon: '{ }',
    accent: 'blue',
    accentText: 'text-blue-400',
    accentBorder: 'border-blue-400/20',
    accentBg: 'bg-blue-400/5',
    skills: [
      { name: 'TypeScript', level: 'expert' },
      { name: 'JavaScript', level: 'expert' },
      { name: 'SQL',        level: 'expert' },
      // { name: 'PHP',        level: 'proficient' },
      // { name: 'Python',     level: 'proficient' },
    ],
  },
  {
    category: 'Frameworks & Runtime',
    icon: '⚡',
    accent: 'indigo',
    accentText: 'text-indigo-400',
    accentBorder: 'border-indigo-400/20',
    accentBg: 'bg-indigo-400/5',
    skills: [
      { name: 'Node.js',    level: 'expert' },
      { name: 'NestJS',     level: 'expert' },
      { name: 'React.js',   level: 'proficient' },
      { name: 'Astro',   level: 'proficient' },
    ],
  },
  {
    category: 'Databases & Cloud',
    icon: '☁',
    accent: 'teal',
    accentText: 'text-teal-400',
    accentBorder: 'border-teal-400/20',
    accentBg: 'bg-teal-400/5',
    skills: [
      { name: 'MongoDB',    level: 'expert' },
      { name: 'MySQL',      level: 'expert' },
      { name: 'AWS S3',     level: 'proficient' },
      { name: 'AWS SES',    level: 'proficient' },
      { name: 'Firebase',   level: 'proficient' },
    ],
  },
  {
    category: 'Tools & Platforms',
    icon: '⚙',
    accent: 'violet',
    accentText: 'text-violet-400',
    accentBorder: 'border-violet-400/20',
    accentBg: 'bg-violet-400/5',
    skills: [
      { name: 'Claude AI',  level: 'expert' },
      { name: 'ChatGPT',    level: 'proficient' },
      { name: 'Blender',    level: 'proficient' },
    ],
  },
];

const levelColors: Record<string, string> = {
  expert:     'text-emerald-400',
  proficient: 'text-amber-400',
  familiar:   'text-slate-500',
};
const levelLabels: Record<string, string> = {
  expert:     'Expert',
  proficient: 'Proficient',
  familiar:   'Familiar',
};
---

<section id="tech" class="relative py-28 px-6 lg:px-12">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto mt-16">

    <!-- ── Section header ─────────────────────────── -->
    <div class="reveal">
      <div class="section-label text-violet-400">
        <span class="glow-dot bg-violet-400" style="color:#8b5cf6;"></span>
        Tech Stack
      </div>
      <h2
        class="font-display font-bold text-white leading-tight"
        style="font-size: clamp(2rem, 5vw, 3.5rem);"
      >
        Skills &amp; Tools
      </h2>
      <p class="mt-3 text-slate-500 max-w-lg">
        The technologies I use to design, build, and ship production software.
      </p>
    </div>

    <!-- ── Legend ─────────────────────────────────── -->
    <div class="mt-8 flex flex-wrap gap-5 reveal reveal-delay-1">
      {Object.entries(levelLabels).map(([key, label]) => (
        <div class="flex items-center gap-2">
          <span class={`font-mono text-xs font-medium ${levelColors[key]}`}>●</span>
          <span class="text-xs text-slate-500 font-mono">{label}</span>
        </div>
      ))}
    </div>

    <!-- ── Skill groups grid ──────────────────────── -->
    <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-5">
      {skillGroups.map((group, gi) => (
        <div
          class={`glass-card reveal reveal-delay-${gi + 1} rounded-2xl p-6 border ${group.accentBorder}`}
        >
          <!-- Group header -->
          <div class="flex items-center gap-3 mb-5">
            <span
              class={`font-mono text-lg ${group.accentText}`}
              aria-hidden="true"
            >{group.icon}</span>
            <h3 class={`font-display font-semibold text-sm tracking-wide ${group.accentText}`}>
              {group.category}
            </h3>
          </div>

          <!-- Skills -->
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <div class="flex items-center gap-1.5">
                <span class={`tech-pill ${group.accentBg} border-opacity-0`}>
                  {skill.name}
                </span>
                {skill.level && (
                  <span class={`font-mono text-xs ${levelColors[skill.level]}`} title={levelLabels[skill.level]}>
                    ●
                  </span>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ── Currently learning ─────────────────────── -->
    <div class="mt-6 reveal reveal-delay-3">
      <div
        class="inline-flex items-center gap-3 px-4 py-3 rounded-xl
               border border-white/6 bg-white/2 text-sm text-slate-500"
      >
        <span>Currently exploring: <span class="text-slate-300 font-medium">DevOps</span></span>
      </div>
    </div>
  </div>
</section>
